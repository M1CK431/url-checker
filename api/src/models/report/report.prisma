enum ReportStatus {
  PENDING
  PROCESSING
  ERROR
  DONE
  DELETED
}

model Report {
  id        Int      @id @default(autoincrement())
  url       String // DB:["sqlite"]
  //url       String @db.VarChar(2083) // DB:["mysql","postgresql"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deleted   Boolean? @default(false)

  http5xxCount Int @default(0)
  http4xxCount Int @default(0)
  http3xxCount Int @default(0)
  http2xxCount Int @default(0)
  http1xxCount Int @default(0)

  processedCount Int @default(0)
  totalCount     Int @default(0)
  duration       Int @default(0) // unit: ms

  status      ReportStatus @default(PENDING)
  errorReason String?

  websiteHost  String // DB:["sqlite"]
  //websiteHost  String @db.VarChar(260) // DB:["mysql","postgresql"]
  website      Website       @relation(fields: [websiteHost], references: [host], onDelete: Cascade)
  checkResults CheckResult[]
}
