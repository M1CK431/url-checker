{
  "name": "url-checker",
  "version": "2.0.0",
  "description": "URL Checker API",
  "main": "src",
  "type": "module",
  "engines": {
    "node": ">=22.17.0",
    "pnpm": ">=9.0.0"
  },
  "repository": "https://github.com/M1CK431/url-checker",
  "author": "M1CK431",
  "license": "GPLv3+ +Commons Clause",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "NODE_ENV=development node --disable-warning=ExperimentalWarning --experimental-transform-types --env-file=.env.development --inspect --watch src/",
    "start": "NODE_ENV=production node --disable-warning=ExperimentalWarning --experimental-transform-types --env-file=.env.production src/",
    "lint": "eslint --fix *.js src/",
    "prisma": "node --env-file=.env.development ./proxsma.js"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0"
  },
  "dependencies": {
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-prisma": "^4.14.3",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/generator-helper": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "domutils": "^4.0.2",
    "graphql": "^16.14.0",
    "graphql-scalars": "^1.25.0",
    "graphql-ws": "^6.0.8",
    "graphql-yoga": "^5.21.0",
    "htmlparser2": "^12.0.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.8.0",
    "ws": "^8.20.0"
  }
}