{
  "name": "url-checker",
  "version": "2.0.0",
  "description": "URL Checker API",
  "main": "src",
  "type": "module",
  "engines": {
    "node": ">=22.7.0",
    "pnpm": ">=9.0.0"
  },
  "repository": "https://github.com/M1CK431/url-checker",
  "author": "M1CK431",
  "license": "GPLv3+ +Commons Clause",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "NODE_ENV=development node --disable-warning=ExperimentalWarning --experimental-transform-types --env-file=.env.development --inspect --watch src/",
    "start": "NODE_ENV=production node --disable-warning=ExperimentalWarning --experimental-transform-types --env-file=.env.production src/",
    "lint": "eslint --fix *.js src/",
    "prisma": "node --env-file=.env.development ./proxsma.js"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "eslint": "^9.30.1",
    "globals": "^16.3.0"
  },
  "dependencies": {
    "@pothos/core": "^4.7.0",
    "@pothos/plugin-prisma": "^4.9.1",
    "@prisma/adapter-better-sqlite3": "^6.11.0",
    "@prisma/client": "^6.11.0",
    "@prisma/generator-helper": "^6.11.0",
    "better-sqlite3": "^11.10.0",
    "domutils": "^3.2.2",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.24.2",
    "graphql-ws": "^6.0.5",
    "graphql-yoga": "^5.14.0",
    "htmlparser2": "^10.0.0",
    "prisma": "^6.11.0",
    "ws": "^8.18.3"
  }
}