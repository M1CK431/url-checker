{
  "name": "url-checker",
  "version": "2.0.0",
  "description": "URL Checker API",
  "main": "src",
  "type": "module",
  "engines": {
    "node": ">=22.17.0",
    "pnpm": ">=9.0.0"
  },
  "repository": "https://github.com/M1CK431/url-checker",
  "author": "M1CK431",
  "license": "GPLv3+ +Commons Clause",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "NODE_ENV=development node --disable-warning=ExperimentalWarning --experimental-transform-types --env-file=.env.development --inspect --watch src/",
    "start": "NODE_ENV=production node --disable-warning=ExperimentalWarning --experimental-transform-types --env-file=.env.production src/",
    "lint": "eslint --fix *.js src/",
    "prisma": "node --env-file=.env.development ./proxsma.js"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0"
  },
  "dependencies": {
    "@pothos/core": "^4.10.0",
    "@pothos/plugin-prisma": "^4.12.0",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@prisma/adapter-better-sqlite3": "^6.18.0",
    "@prisma/adapter-mariadb": "^6.19.0",
    "@prisma/adapter-pg": "^6.19.0",
    "@prisma/client": "^6.18.0",
    "@prisma/generator-helper": "^6.18.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "domutils": "^3.2.2",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "graphql-ws": "^6.0.6",
    "graphql-yoga": "^5.16.0",
    "htmlparser2": "^10.0.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.18.0",
    "ws": "^8.18.3"
  }
}